# Paid Zoho organization/domain account: smtppro.zoho.com
# Personal/free Zoho Mail account: smtp.zoho.com
# Zoho shows the exact server for your mailbox under Mail > Settings > Mail Accounts > Server Configuration Details.
ZOHO_SMTP_HOST=smtppro.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_SECURE=true
ZOHO_SMTP_USER=info@prometo.app
ZOHO_SMTP_PASS=replace-with-zoho-app-password
BETA_FORM_TO=info@prometo.app
BETA_FORM_FROM=Prometo Website <info@prometo.app>
BETA_FORM_ALLOWED_ORIGINS=https://prometo.app,https://www.prometo.app
